# Polymarket Keys
POLYMARKET_PRIVATE_KEY=<your-metamask-private-key>
POLYMARKET_FUNDER=<polymarket-proxy-wallet-address>

# Optional: a Polygon RPC URL enables on-chain redemption so EVERY resolved
# position is cleared from the wallet (winner -> USDC, loser -> burned to $0),
# leaving no shares sitting around. Any Polygon RPC works, e.g. a free public one:
#   POLYGON_RPC_URL=https://polygon-rpc.com
# Redeeming costs ~$0.001 gas per position, so keep a little POL in the EOA. When
# unset, the bot only REPORTS what's claimable and never sends an on-chain tx.
POLYGON_RPC_URL=

# Discord (for trade alerts and commands)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
